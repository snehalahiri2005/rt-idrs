# Copy this file to .env and fill in your values.
# docker-compose automatically reads variables from .env

DOCKERHUB_USER=yourdockerhub
IMAGE_TAG=latest

# Optional: Slack incoming webhook URL for alert notifications
SLACK_WEBHOOK_URL=

# --- Email alert configuration ---
# RT-IDRS can send an email to the system owner/administrator (the
# "person being attacked") whenever a medium/high severity incident
# is detected. Leave SMTP_HOST blank to disable email alerts entirely.
#
# Example for Gmail (use an "App Password", not your normal password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USERNAME=youraccount@gmail.com
#   SMTP_PASSWORD=your-app-password
#   ALERT_EMAIL_FROM=youraccount@gmail.com
#   ALERT_EMAIL_TO=victim@example.com,soc-team@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=snehalahiri73@gmail.com
SMTP_PASSWORD=vajpaheltyfrruaz
ALERT_EMAIL_FROM=snehalahiri73@gmail.com
ALERT_EMAIL_TO=1by23is212@bmsit.in
# Minimum severity that triggers an email: low | medium | high
ALERT_EMAIL_MIN_SEVERITY=medium

# Set to "false" if you are running in an environment where iptables
# cannot be modified (e.g. some CI runners) - the system will simulate
# blocking instead.
ENABLE_IPTABLES=true
