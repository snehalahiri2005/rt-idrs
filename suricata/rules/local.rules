# ------------------------------------------------------------------
# Custom local detection rules for RT-IDRS
# Format: action proto src_ip src_port -> dst_ip dst_port (options)
# ------------------------------------------------------------------

# 1. Detect ICMP flood (basic ping sweep / DoS indicator)
alert icmp any any -> $HOME_NET any (msg:"ICMP Flood / Ping Sweep Detected"; itype:8; threshold:type both, track by_src, count 20, seconds 10; classtype:attempted-dos; sid:1000001; rev:1;)

# 2. Detect TCP SYN port scan (many SYNs to many ports from one host)
alert tcp any any -> $HOME_NET any (msg:"Possible TCP Port Scan Detected"; flags:S; threshold:type both, track by_src, count 30, seconds 10; classtype:attempted-recon; sid:1000002; rev:1;)

# 3. Detect SSH brute force attempts (many connections to port 22)
alert tcp any any -> $HOME_NET 22 (msg:"Possible SSH Brute Force Attempt"; flags:S; threshold:type both, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:1000003; rev:1;)

# 4. Detect HTTP request to a suspicious admin path (basic web attack indicator)
alert http any any -> $HOME_NET any (msg:"Suspicious Access to Admin Path"; http.uri; content:"/wp-admin"; nocase; classtype:web-application-attack; sid:1000004; rev:1;)

# 5. Detect known malicious User-Agent string (example of signature-based detection)
alert http any any -> $HOME_NET any (msg:"Suspicious User-Agent (Scanner Tool)"; http.user_agent; content:"sqlmap"; nocase; classtype:web-application-attack; sid:1000005; rev:1;)

# 6. Detect FTP brute force
alert tcp any any -> $HOME_NET 21 (msg:"Possible FTP Brute Force Attempt"; flags:S; threshold:type both, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:1000006; rev:1;)
